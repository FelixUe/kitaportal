# ══════════════════════════════════════════════════════════════════
# KitaPortal – Produktionskonfiguration
# ══════════════════════════════════════════════════════════════════
#
# Anleitung:
#   1. Diese Datei als ".env.prod" speichern
#   2. Alle Werte unterhalb ausfüllen
#   3. Die Datei sicher aufbewahren – sie enthält Passwörter!
#      Niemals in Git einchecken oder per E-Mail versenden.
#
# Das Setup-Skript (setup.sh) erledigt das automatisch.
# ══════════════════════════════════════════════════════════════════

# ── Domain ───────────────────────────────────────────────────────
# Deine Domain, unter der KitaPortal erreichbar sein soll.
# Ohne "https://" und ohne abschließenden Schrägstrich.
# Beispiel: kita.sonnenschein.de
DOMAIN=kita.meinedomain.de

# ── E-Mail ───────────────────────────────────────────────────────
# Deine E-Mail-Adresse. Wird benötigt, damit Let's Encrypt dir
# wichtige Meldungen zum SSL-Zertifikat schicken kann
# (z.B. wenn es bald abläuft).
ADMIN_EMAIL=leiterin@meinekita.de

# ── Geheimer Schlüssel (Django) ──────────────────────────────────
# Ein langer, zufälliger Schlüssel für die Sicherheit der App.
# Mindestens 50 Zeichen. Einmal festlegen und nicht mehr ändern.
#
# Neuen Schlüssel generieren:
#   openssl rand -base64 48 | tr -d '/+=' | head -c 50
SECRET_KEY=HIER_EINEN_LANGEN_ZUFAELLIGEN_SCHLUESSEL_EINTRAGEN

# ── Datenbankpasswort ────────────────────────────────────────────
# Passwort für die interne Datenbank. Muss nur einmal festgelegt
# werden. Mindestens 20 Zeichen empfohlen.
#
# Neues Passwort generieren:
#   openssl rand -hex 24
DB_PASSWORD=HIER_EIN_SICHERES_DATENBANKPASSWORT_EINTRAGEN
